<%- include('header') %>

<div class="flex-between" style="align-items: flex-start; margin-bottom: 16px;">
    <div>
        <h2 style="margin-bottom: 4px;">
            <a href="<%= ownerIsOrg ? '/org/' : '/user/' %><%= repo.owner %>"><%= repo.owner %></a> / 
            <a href="/<%= repo.owner %>/<%= repo.name %>" style="font-weight: 700;"><%= repo.name %></a>
            <span class="text-muted" style="font-size: 0.9rem; font-weight: 400; border: 1px solid var(--border-color); padding: 2px 8px; border-radius: 12px; margin-left: 8px;">
                <%= repo.isPrivate ? 'Private' : 'Public' %>
            </span>
        </h2>
        <% if (repo.description) { %>
        <p class="text-muted" style="margin-top: 4px; margin-bottom: 0; font-size: 1rem;"><%= repo.description %></p>
        <% } %>
    </div>
    <div style="display: flex; gap: 8px;">
        <button class="btn">Watch</button>
        <button class="btn">Star</button>
        <% if (user && user.username !== repo.owner) { %>
        <form action="/<%= repo.owner %>/<%= repo.name %>/fork" method="POST" style="margin: 0;">
            <button type="submit" class="btn">Fork</button>
        </form>
        <% } else { %>
        <button class="btn" disabled title="You cannot fork your own repository">Fork</button>
        <% } %>
    </div>
</div>

<div style="margin-bottom: 24px; border-bottom: 1px solid var(--border-color); display: flex; gap: 24px;">
    <a href="/<%= repo.owner %>/<%= repo.name %><%= currentBranch ? '?branch=' + currentBranch : '' %>" style="padding: 8px 0; border-bottom: 2px solid var(--primary-color); font-weight: 600;">Code</a>
    <a href="/<%= repo.owner %>/<%= repo.name %>/pulls" style="padding: 8px 0; color: var(--fg-color);">Pull Requests</a>
    <a href="/<%= repo.owner %>/<%= repo.name %>/releases" style="padding: 8px 0; color: var(--fg-color);">Releases</a>
    <% if (user && user.username === repo.owner) { %>
    <a href="/<%= repo.owner %>/<%= repo.name %>/settings" style="padding: 8px 0; color: var(--fg-color);">Settings</a>
    <% } %>
</div>

<div class="card" style="padding: 12px 16px; margin-bottom: 16px; background-color: var(--bg-color); border-color: var(--border-color);">
    <code style="font-size: 0.9rem; color: var(--fg-color);">
        git clone <%= baseUrl %>/<%= repo.owner %>/<%= repo.name %>.git
    </code>
</div>

<div style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
    <svg aria-hidden="true" height="16" viewBox="0 0 16 16" version="1.1" width="16" fill="currentColor">
        <path d="M11.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm-2.25.75a2.25 2.25 0 1 1 3 2.122V6A2.5 2.5 0 0 1 10 8.5H6a1 1 0 0 0-1 1v1.122a2.25 2.25 0 1 1-1.5 0V5.378a2.25 2.25 0 1 1 1.5 0v1.836A2.492 2.492 0 0 1 6 7h4a1 1 0 0 0 1-1v-.628A2.25 2.25 0 0 1 9.5 3.25ZM4.25 12a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5ZM3.5 3.25a.75.75 0 1 1 1.5 0 .75.75 0 0 1-1.5 0Z"></path>
    </svg>
    <select onchange="window.location.href='?branch=' + this.value" class="btn" style="padding: 4px 8px; font-weight: 600;">
        <% if (branches.length === 0) { %>
            <option value="<%= currentBranch %>"><%= currentBranch %></option>
        <% } else { %>
            <% branches.forEach(b => { %>
                <option value="<%= b %>" <%= currentBranch === b ? 'selected' : '' %>><%= b %></option>
            <% }); %>
        <% } %>
    </select>
</div>

<div class="card" style="padding: 0; overflow: hidden;">
    <div style="background-color: var(--bg-color); padding: 12px 16px; border-bottom: 1px solid var(--border-color);">
        <h3 style="margin-bottom: 0; font-size: 1rem;">Latest Commits (<%= currentBranch %>)</h3>
    </div>
    <div style="padding: 16px;">
        <% if (commits.length === 0 || commits[0] === 'Empty repository') { %>
            <p class="text-muted">No commits yet.</p>
        <% } else { %>
            <ul style="list-style: none;">
                <% commits.forEach(commit => { %>
                    <li style="padding: 8px 0; border-bottom: 1px solid var(--border-color);">
                        <code><%= commit.substring(0, 7) %></code> <%= commit.substring(8) %>
                    </li>
                <% }); %>
            </ul>
        <% } %>
    </div>
</div>

<% 
  let fileList = [];
  files.forEach((file, index) => {
      const isReadmeOrLicense = file.toLowerCase().startsWith('readme') || file.toLowerCase().startsWith('license');
      let shouldHide = false;
      if (files.length > 6) {
          if (index >= 6 && !isReadmeOrLicense) {
              shouldHide = true;
          }
      }
      fileList.push({ name: file, shouldHide });
  });
  const hasHiddenFiles = fileList.some(f => f.shouldHide);
%>
<div class="file-explorer" id="fileExplorer">
    <div style="background-color: var(--bg-color); padding: 12px 16px; border-bottom: 1px solid var(--border-color);">
        <h3 style="margin-bottom: 0; font-size: 1rem;">Files</h3>
    </div>
    <% if (files.length === 0) { %>
        <div style="padding: 32px; text-align: center;">
            <p class="text-muted">This repository is empty.</p>
            <p class="text-muted" style="font-size: 0.85rem; margin-top: 8px;">
                Push some code to get started!
            </p>
        </div>
    <% } else { %>
        <% fileList.forEach(file => { %>
            <div class="file-row <%= file.shouldHide ? 'hidden-file' : '' %>" style="<%= file.shouldHide ? 'display: none;' : '' %>">
                <span style="margin-right: 12px;">📄</span>
                <a href="#"><%= file.name %></a>
            </div>
        <% }); %>
        <% if (hasHiddenFiles) { %>
            <div id="showMoreContainer" style="padding: 12px 16px; border-top: 1px solid var(--border-color); text-align: center;">
                <button class="btn" id="showMoreBtn" onclick="toggleFiles()">Show more</button>
            </div>
        <% } %>
    <% } %>
</div>

<% if (hasHiddenFiles) { %>
<script>
    function toggleFiles() {
        const hiddenFiles = document.querySelectorAll('.hidden-file');
        const showMoreBtn = document.getElementById('showMoreBtn');
        const isCollapsed = hiddenFiles[0].style.display === 'none';
        
        hiddenFiles.forEach(el => {
            el.style.display = isCollapsed ? 'flex' : 'none';
        });
        
        showMoreBtn.textContent = isCollapsed ? 'Show less' : 'Show more';
    }
</script>
<% } %>

<% if (readmeContent) { %>
<div class="card" style="margin-top: 24px; padding: 24px;">
    <div id="readme-raw" style="display: none;"><%= readmeContent %></div>
    <div id="readme-rendered" style="font-family: sans-serif; line-height: 1.6;"></div>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script>
        const raw = document.getElementById('readme-raw').textContent;
        document.getElementById('readme-rendered').innerHTML = marked.parse(raw);
    </script>
</div>
<% } %>

<%- include('footer') %>
