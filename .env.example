PORT=3210
SESSION_SECRET=a-very-secret-session-key
# Must be 32 characters for AES-256-CBC
DB_ENCRYPTION_KEY=my-super-secret-encryption-key-32
MAIN_DOMAIN=nodebruv.nodemixaholic.com
PAGES_DOMAIN=pages.nodebruv.nodemixaholic.com
BRUV_BLOCK_ENV_FILES=true
BRUV_BLOCKED_PATTERNS=.env,.env.*,*.pem,*.key,id_rsa,id_ed25519,credentials.json,service-account.json,secrets.yml,secrets.yaml,.npmrc,.pypirc,.netrc

# bruv API server URL (port 2658 by default)
BRUV_API_URL=http://localhost:2658
